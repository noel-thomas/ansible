# {{ ansible_managed }}
# Custom nginx site config — managed by Ansible. Do not edit by hand.

server {
    listen       {{ nginx_listen_port | default(80) }} default_server;
    server_name  _;

    root   /var/www/html;
    index  index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location /health {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }

    # Hint to the browser that this came from Ansible
    add_header X-Managed-By "Ansible" always;
    add_header X-Webinar "{{ webinar_title }}" always;
}
