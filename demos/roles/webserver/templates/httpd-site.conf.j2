# {{ ansible_managed }}
# Generated by the `webserver` role.
#
# Note: we do NOT declare `Listen` here — /etc/httpd/conf/httpd.conf already
# does that and Apache rejects duplicate Listen on the same IP:port.

<VirtualHost *:{{ nginx_listen_port }}>
    ServerName {{ nginx_server_name }}
    DocumentRoot {{ site_doc_root }}

    <Directory "{{ site_doc_root }}">
        Options Indexes FollowSymLinks
        AllowOverride None
        Require all granted
        DirectoryIndex index.html
    </Directory>

    # /health is served as a static file dropped by the role (Apache cannot
    # return an inline response body the way nginx can).
    <Files "health">
        ForceType text/plain
    </Files>

    Header always set X-Managed-By "Ansible (webserver role)"
    Header always set X-App         "{{ app_name | default('unknown') }}"
    Header always set X-Environment "{{ app_environment | default('unknown') }}"
</VirtualHost>
