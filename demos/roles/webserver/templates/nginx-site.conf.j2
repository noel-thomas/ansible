# {{ ansible_managed }}
# Generated by the `webserver` role.

server {
    listen       {{ nginx_listen_port }} default_server;
    server_name  {{ nginx_server_name }};

    root   {{ site_doc_root }};
    index  index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location = /health {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }

    add_header X-Managed-By "Ansible (webserver role)" always;
    add_header X-App         "{{ app_name | default('unknown') }}" always;
    add_header X-Environment "{{ app_environment | default('unknown') }}" always;
}
