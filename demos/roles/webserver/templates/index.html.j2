<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ site_heading }}</title>
  <meta name="generator" content="Ansible {{ ansible_version.full | default('?') }}">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
           max-width: 720px; margin: 4em auto; padding: 0 1em; color: #222; }
    h1 { color: #1a4d8f; border-bottom: 3px solid #1a4d8f; padding-bottom: .3em; }
    .sub { color: #666; font-size: 1.1em; margin-top: -.5em; }
    table { border-collapse: collapse; margin-top: 2em; width: 100%; }
    td, th { padding: .5em .8em; border-bottom: 1px solid #eee; text-align: left; }
    th { background: #f4f6fa; }
    code { background: #f4f4f4; padding: 2px 6px; border-radius: 3px; }
    .footer { margin-top: 3em; color: #999; font-size: .9em; }
  </style>
</head>
<body>
  <h1>{{ site_heading }}</h1>
  <p class="sub">{{ site_subheading }}</p>

  <p>This page was deployed by Ansible. The infrastructure underneath
     it was discovered automatically — no human typed any of these values.</p>

  <table>
    <tr><th>Host</th>            <td>{{ inventory_hostname }}</td></tr>
    <tr><th>OS</th>              <td>{{ ansible_facts['distribution'] }} {{ ansible_facts['distribution_version'] }}</td></tr>
    <tr><th>Kernel</th>          <td>{{ ansible_facts['kernel'] }}</td></tr>
    <tr><th>Architecture</th>    <td>{{ ansible_facts['architecture'] }}</td></tr>
    <tr><th>vCPUs</th>           <td>{{ ansible_facts['processor_vcpus'] | default('?') }}</td></tr>
    <tr><th>Memory</th>          <td>{{ (ansible_facts['memtotal_mb'] / 1024) | round(1) }} GB</td></tr>
    <tr><th>Application</th>     <td>{{ app_name | default('?') }}</td></tr>
    <tr><th>Environment</th>     <td>{{ app_environment | default('?') }}</td></tr>
    <tr><th>Deployed at</th>     <td>{{ ansible_date_time.iso8601 }}</td></tr>
  </table>

  <p class="footer">
    Generated by Ansible — {{ ansible_managed }}
  </p>
</body>
</html>
